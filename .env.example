# AWS Cognito OIDC Configuration
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your_client_id_here
VITE_COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
VITE_REDIRECT_URI=http://localhost:3000
VITE_LOGOUT_URI=http://localhost:3000

# API Configuration
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev/v1

# Tenant ID (will be extracted from Cognito JWT custom claims in production)
VITE_TENANT_ID=

# Optional: Gemini API Key (for AI features)
GEMINI_API_KEY=your_api_key_here
